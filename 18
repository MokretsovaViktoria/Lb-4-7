sentence = input('Введите предложение: ')

count_gl = 0  # Кол-во гласных
count_sogl = 0  # Кол-во согласных

for i in sentence:
    if i == ' ':
      continue
    if i in 'аоуэыяёюеи':
      count_gl += 1
    else:
      count_sogl += 1

print('Кол-во букв в предложении: гласных - {}, согласных - {}'.format(count_gl, count_sogl))

